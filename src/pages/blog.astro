---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/sections/Navbar.astro';
import Footer from '../components/sections/Footer.astro';
import { getBlogPosts } from '../data/blog.ts';

const blogPosts = await getBlogPosts();
---

<Layout title="Blog | RIO_PERSONAL_WEB">
  <!-- OS Desktop Background -->
  <div class="desktop-background"></div>

  <!-- Navbar -->
  <Navbar />

  <!-- Main Container -->
  <div class="main-container window-border" style="margin-top: 70px;">
    <div class="blog-content">
      <!-- Blog Header -->
      

      <div class="blog-body">
        <h1 class="blog-title">BLOGS</h1>
        <p class="blog-subtitle">Security research write-ups, tutorials, and case studies</p>

        <!-- Search -->
        <div class="search-container">
          <div class="search-prompt">
            <span class="prompt">$</span>
            <input
              type="text"
              id="search-input"
              class="search-input"
              placeholder="grep --search"
              autocomplete="off"
            />
            <span class="cursor">_</span>
          </div>
          <div class="search-results-count" id="results-count"></div>
        </div>

        <!-- Filters -->
        <div class="filter-container">
          <span class="filter-label">TAGS:</span>
          <div class="filter-tags" id="filter-tags">
            <button class="filter-tag active" data-filter="all">ALL</button>
            <button class="filter-tag" data-filter="Mobile">Mobile</button>
            <button class="filter-tag" data-filter="WriteUp">WriteUp</button>
            <button class="filter-tag" data-filter="Bug Bounty">Bug Bounty</button>
            <button class="filter-tag" data-filter="Web Security">Web Security</button>
          </div>
        </div>

        <!-- Blog Grid -->
        <div class="blog-grid" id="blog-grid">
          {blogPosts.map((post) => (
            <article class="blog-post" data-title={post.title} data-category={post.category} data-tags={post.tags.join(',')} data-excerpt={post.excerpt}>
              <div class="post-thumbnail">
                <img src={post.thumbnail} alt={post.title} />
              </div>
              <div class="post-body">
                <div class="post-header">
                  <div class="post-meta">
                    <span class="post-date">[{post.date}]</span>
                    <span class="post-category">{post.category}</span>
                  </div>
                </div>
                <h2 class="post-title">{post.title}</h2>
                <p class="post-excerpt">{post.excerpt}</p>
                <div class="post-footer">
                  <div class="post-tags">
                    {post.tags.map((tag) => (
                      <span class="post-tag">{tag}</span>
                    ))}
                  </div>
                  <a href={`/blog/${post.year}/${post.month}/${post.slug}`} class="post-link">Read →</a>
                </div>
              </div>
            </article>
          ))}
        </div>

        <!-- No Results -->
        <div class="no-results" id="no-results" style="display: none;">
          <div class="terminal-line">
            <span class="prompt">$</span>
            <span class="error-text">grep: no matches found</span>
          </div>
        </div>
      </div>
    </div>

    <Footer />
  </div>
</Layout>

<script>
  // Blog Search and Filter Functionality
  const searchInput = document.getElementById('search-input') as HTMLInputElement;
  const resultsCount = document.getElementById('results-count') as HTMLElement;
  const blogGrid = document.getElementById('blog-grid') as HTMLElement;
  const noResults = document.getElementById('no-results') as HTMLElement;
  const filterTags = document.querySelectorAll('.filter-tag');
  const posts = document.querySelectorAll('.blog-post');

  let activeFilter = 'all';

  function filterPosts() {
    const query = searchInput.value.toLowerCase().trim();
    let visibleCount = 0;

    posts.forEach((post) => {
      const title = post.getAttribute('data-title')?.toLowerCase() || '';
      const category = post.getAttribute('data-category')?.toLowerCase() || '';
      const tags = post.getAttribute('data-tags')?.toLowerCase() || '';
      const excerpt = post.getAttribute('data-excerpt')?.toLowerCase() || '';

      const matchesSearch = !query ||
        title.includes(query) ||
        category.includes(query) ||
        tags.includes(query) ||
        excerpt.includes(query);

      const matchesFilter = activeFilter === 'all' ||
        category.includes(activeFilter.toLowerCase()) ||
        tags.includes(activeFilter.toLowerCase());

      if (matchesSearch && matchesFilter) {
        post.classList.remove('hidden');
        visibleCount++;
      } else {
        post.classList.add('hidden');
      }
    });

    // Toggle grid visibility
    if (visibleCount === 0) {
      blogGrid.style.display = 'none';
      noResults.style.display = 'block';
    } else {
      blogGrid.style.display = 'grid';
      noResults.style.display = 'none';
    }

    // Update results count
    resultsCount.textContent = query
      ? `${visibleCount} match${visibleCount !== 1 ? 'es' : ''} found`
      : `${visibleCount} entries in /bin/BLOG`;
  }

  // Search input event
  searchInput?.addEventListener('input', filterPosts);

  // Filter tag clicks
  filterTags.forEach((tag) => {
    tag.addEventListener('click', () => {
      filterTags.forEach((t) => t.classList.remove('active'));
      tag.classList.add('active');
      activeFilter = tag.getAttribute('data-filter') || 'all';
      filterPosts();
    });
  });

  // Initial count
  filterPosts();
</script>

<style>
  .desktop-background {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #0c0c0c;
    background-image:
      linear-gradient(rgba(34, 34, 34, 0.5) 1px, transparent 1px),
      linear-gradient(90deg, rgba(34, 34, 34, 0.5) 1px, transparent 1px);
    background-size: 50px 50px;
    z-index: -1;
  }

  .main-container {
    width: 90%;
    max-width: 1300px;
    margin: 70px auto 0 auto;
    background: #e5e5e5;
    position: relative;
    z-index: 1;
    min-height: 100vh;
    overflow: hidden;
  }

  .blog-content {
    padding: 0;
  }

  .blog-body {
    padding: 2rem;
  }

  .blog-title {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    text-transform: uppercase;
  }

  .blog-subtitle {
    color: #666;
    font-size: 0.875rem;
    margin-bottom: 2rem;
  }

  /* Search */
  .search-container {
    margin-bottom: 2rem;
  }

  .search-prompt {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    background: #000;
    border: 2px solid #000;
    padding: 1rem 1.5rem;
    font-family: "IBM Plex Mono", monospace;
  }

  .prompt {
    color: #00ff00;
    font-size: 1rem;
    flex-shrink: 0;
  }

  .search-input {
    flex: 1;
    background: transparent;
    border: none;
    color: #fff;
    font-family: "IBM Plex Mono", monospace;
    font-size: 1rem;
    outline: none;
  }

  .search-input::placeholder {
    color: #666;
  }

  .cursor {
    color: #00ff00;
    animation: blink 1s infinite;
    font-size: 1rem;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .search-results-count {
    font-size: 0.75rem;
    color: #666;
    margin-top: 0.5rem;
    padding-left: 1.5rem;
    font-family: "IBM Plex Mono", monospace;
  }

  /* Filters */
  .filter-container {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .filter-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
  }

  .filter-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .filter-tag {
    padding: 0.375rem 0.75rem;
    border: 2px solid #000;
    background: #e5e5e5;
    font-family: "IBM Plex Mono", monospace;
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
  }

  .filter-tag:hover,
  .filter-tag.active {
    background: #000;
    color: #fff;
  }

  /* Blog Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
    gap: 1.5rem;
  }

  .blog-post {
    border: 2px solid #000;
    background: #fff;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s, box-shadow 0.3s;
    overflow: hidden;
  }

  .blog-post:hover {
    transform: translate(-4px, -4px);
    box-shadow: 8px 8px 0 #000;
  }

  .blog-post.hidden {
    display: none;
  }

  .post-thumbnail {
    width: 100%;
    aspect-ratio: 16/9;
    overflow: hidden;
    border-bottom: 2px solid #000;
    background: #000;
  }

  .post-thumbnail img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: grayscale(100%) contrast(1.1);
    transition: filter 0.3s, transform 0.3s;
  }

  .blog-post:hover .post-thumbnail img {
    filter: grayscale(0%) contrast(1);
    transform: scale(1.05);
  }

  .post-body {
    padding: 1.5rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .post-header {
    margin-bottom: 0.10rem;
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .post-date {
    color: #666;
  }

  .post-category {
    background: #000;
    color: #fff;
    padding: 0.125rem 0.5rem;
  }

  .post-title {
    font-size: 1.125rem;
    margin-bottom: 0.75rem;
    line-height: 1.3;
  }

  .post-excerpt {
    font-size: 0.8125rem;
    color: #333;
    margin-bottom: 1.5rem;
    line-height: 1.6;
    flex-grow: 1;
  }

  .post-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 2px solid #000;
    padding-top: 1rem;
  }

  .post-tags {
    display: flex;
    gap: 0.375rem;
    flex-wrap: wrap;
  }

  .post-tag {
    font-size: 0.6875rem;
    background: #e5e5e5;
    padding: 0.25rem 0.5rem;
    border: 1px solid #000;
  }

  .post-link {
    font-size: 0.875rem;
    font-weight: 700;
    text-transform: uppercase;
    color: #000;
    transition: color 0.2s;
  }

  .post-link:hover {
    color: #00ff00;
  }

  /* No Results */
  .no-results {
    padding: 2rem;
    background: #000;
    border: 2px solid #000;
    font-family: "IBM Plex Mono", monospace;
  }

  .no-results .terminal-line {
    display: flex;
    gap: 0.75rem;
    font-size: 1rem;
  }

  .error-text {
    color: #ff4444;
  }

  @media (max-width: 768px) {
    .main-container {
      width: 95%;
      margin: 70px auto 0 auto;
    }

    .blog-body {
      padding: 1rem;
    }

    .blog-title {
      font-size: 1.5rem;
    }

    .blog-grid {
      grid-template-columns: 1fr;
    }

    .search-prompt {
      padding: 0.75rem 1rem;
    }

    .filter-container {
      gap: 0.5rem;
    }

    .filter-tag {
      padding: 0.25rem 0.5rem;
      font-size: 0.6875rem;
    }

    .blog-post:hover {
      transform: none;
      box-shadow: none;
    }
  }
</style>
