<style>
  .designer-log {
    background: #e5e5e5;
    margin: 2rem;
    overflow: hidden;
  }

  .designer-log-content {
    padding: 2rem;
  }

  .log-section {
    margin-bottom: 1.5rem;
  }

  .log-section:last-child {
    margin-bottom: 0;
  }

  .log-heading {
    font-size: 1.25rem;
    margin-bottom: 1rem;
    font-weight: 700;
  }

  .log-line {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 0.875rem;
  }

  .timestamp {
    color: #666;
    font-weight: 700;
    min-width: 120px;
  }

  .message {
    color: #000;
  }

  .divider {
    height: 2px;
    background: #000;
    margin: 1.5rem 0;
  }
</style>
